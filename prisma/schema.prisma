generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id                     String       @id @default(cuid())
  email                  String       @unique
  emailVerified          DateTime?
  name                   String?
  image                  String?
  avatarUrl              String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String       @default("TRIAL")
  trialEndsAt            DateTime?
  timezone               String       @default("America/Chicago")
  reminderTime           String       @default("21:00")
  pushToken              String?
  createdAt              DateTime     @default(now())
  accounts               Account[]
  sessions               Session[]
  entries                Entry[]
  tasks                  Task[]
  goals                  Goal[]
  weeklyReports          WeeklyReport[]
  lifemapAreas           LifeMapArea[]
  memory                 UserMemory?
}

model Entry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  audioUrl      String?
  duration      Int?
  audioDuration Int?
  transcript    String?
  summary       String?
  mood          String?
  moodScore     Int?
  energy        Int?
  themes        String[]
  wins          String[]
  blockers      String[]
  rawExtraction Json?
  rawAnalysis   Json?
  status        String   @default("PENDING")
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
}

model Task {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  entryId      String?
  entry        Entry?    @relation(fields: [entryId], references: [id])
  text         String?
  title        String?
  description  String?
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  dueDate      DateTime?
  snoozedUntil DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  description   String?
  lifeArea      String    @default("PERSONAL")
  status        String    @default("ACTIVE")
  targetDate    DateTime?
  progress      Int       @default(0)
  progressNotes Json[]
  entryRefs     String[]
  createdAt     DateTime  @default(now())
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  weekStart       DateTime
  weekEnd         DateTime
  weekNumber      Int
  year            Int
  narrative       String?
  insightBullets  String[]
  moodArc         String?
  topThemes       String[]
  tasksOpened     Int      @default(0)
  tasksClosed     Int      @default(0)
  goalsProgressed String[]
  entryCount      Int      @default(0)
  status          String   @default("GENERATING")
  createdAt       DateTime @default(now())
}

model LifeMapArea {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  area            String    @default("")
  name            String?
  color           String?
  icon            String?
  sortOrder       Int       @default(0)
  score           Int       @default(5)
  summary         String?
  activeGoals     Int       @default(0)
  lastMentioned   DateTime?
  trend           String?   // "up", "down", "stable"
  weeklyDelta     Int?
  monthlyDelta    Int?
  mentionCount    Int       @default(0)
  topThemes       String[]
  insightSummary  String?
  historicalHigh  Int       @default(0)
  historicalLow   Int       @default(100)
  baselineScore   Int       @default(50)
  updatedAt       DateTime  @updatedAt
}

model UserMemory {
  id        String @id @default(cuid())
  userId    String @unique
  user      User   @relation(fields: [userId], references: [id])

  // Compressed lifetime summary per area (AI-generated, updated incrementally)
  healthSummary        String?
  wealthSummary        String?
  relationshipSummary  String?
  spiritualitySummary  String?
  careerSummary        String?
  growthSummary        String?

  // Lifetime mention counts per area
  healthMentions       Int @default(0)
  wealthMentions       Int @default(0)
  relationshipMentions Int @default(0)
  spiritualityMentions Int @default(0)
  careerMentions       Int @default(0)
  growthMentions       Int @default(0)

  // Recurring patterns detected across all time
  recurringThemes Json[] // { area, theme, firstSeen, count, lastSeen }
  recurringPeople Json[] // { name, area, sentiment, mentionCount }
  recurringGoals  Json[] // { goal, area, firstMentioned, status, mentionCount }

  // Baseline scores (lifetime average, updated slowly)
  healthBaseline       Int @default(50)
  wealthBaseline       Int @default(50)
  relationshipBaseline Int @default(50)
  spiritualityBaseline Int @default(50)
  careerBaseline       Int @default(50)
  growthBaseline       Int @default(50)

  // Total entries processed
  totalEntries   Int       @default(0)
  firstEntryDate DateTime?
  lastCompressed DateTime?
  lastUpdated    DateTime  @updatedAt
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  source    String?
  createdAt DateTime @default(now())
}
