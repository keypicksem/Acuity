generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  name                   String?
  avatarUrl              String?
  stripeCustomerId       String?
  stripeSubscriptionId   String?
  stripeCurrentPeriodEnd DateTime?
  subscriptionStatus     String    @default("TRIAL")
  trialEndsAt            DateTime?
  timezone               String    @default("America/Chicago")
  reminderTime           String    @default("21:00")
  pushToken              String?
  createdAt              DateTime  @default(now())
  entries                Entry[]
  tasks                  Task[]
  goals                  Goal[]
  weeklyReports          WeeklyReport[]
  lifemapAreas           LifeMapArea[]
}

model Entry {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  audioUrl      String?
  duration      Int?
  transcript    String?
  summary       String?
  mood          String?
  moodScore     Int?
  themes        String[]
  rawExtraction Json?
  status        String   @default("PENDING")
  entryDate     DateTime @default(now())
  createdAt     DateTime @default(now())
  tasks         Task[]
}

model Task {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  entryId      String?
  entry        Entry?    @relation(fields: [entryId], references: [id])
  text         String
  status       String    @default("OPEN")
  priority     String    @default("MEDIUM")
  dueDate      DateTime?
  snoozedUntil DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  title         String
  description   String?
  lifeArea      String    @default("PERSONAL")
  status        String    @default("ACTIVE")
  targetDate    DateTime?
  progressNotes Json[]
  entryRefs     String[]
  createdAt     DateTime  @default(now())
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  weekStart       DateTime
  weekEnd         DateTime
  weekNumber      Int
  year            Int
  narrative       String?
  insightBullets  String[]
  moodArc         String?
  topThemes       String[]
  tasksOpened     Int      @default(0)
  tasksClosed     Int      @default(0)
  goalsProgressed String[]
  entryCount      Int      @default(0)
  status          String   @default("GENERATING")
  createdAt       DateTime @default(now())
}

model LifeMapArea {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  area          String
  score         Int       @default(5)
  summary       String?
  activeGoals   Int       @default(0)
  lastMentioned DateTime?
  updatedAt     DateTime  @updatedAt
}
