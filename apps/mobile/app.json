{
  "expo": {
    "name": "Acuity",
    "slug": "acuity",
    "version": "1.0.0",
    "owner": "acuity",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "acuity",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#09090B"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.acuity.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Acuity uses the microphone to record your nightly brain dump."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#09090B"
      },
      "package": "com.acuity.app",
      "permissions": ["RECORD_AUDIO"]
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Acuity needs mic access to record your brain dump."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
